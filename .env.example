#

#Secret to sign JWT tokens
JWT_SECRET=

#Token expiration time
JWT_EXPIRES_IN=1h

#Default administrator email
EMAIL_GOD=goduser@email.com     #example email, can be changed

#Default administrator password
#Requirements: minimum 6 characters, at least 1 lowercase, 1 uppercase, 1 special character, and 1 number
SENHA_GOD=

#Database connection
#Inside Docker, MARIA_HOST should be db (service name in docker-compose)
#Outside Docker use "localhost"
MARIA_HOST=db
MARIA_PORT=3306
MARIA_DB=
MARIA_USER=
MARIA_PASSWORD=
MARIA_ROOT_PASSWORD=

#Execution environment ("production" or "development")
NODE_ENV=production

#CORS allowed origins, separated by comma. In production, replace with your actual domain (e.g. https://proxy.lscad.facom.ufms.br,https://lscad.facom.ufms.br)
ALLOWED_ORIGINS=http://server.localhost,http://wordpress.localhost

# Domain used by Traefik to route traffic (e.g. server.localhost or proxy.dominio.com.br)
APP_HOST=server.localhost
# Domain used by Traefik to route WordPress (e.g. wordpress.localhost or dominio.com.br)
WORDPRESS_HOST=wordpress.localhost

# WordPress database (can be the same as the app for local testing)
WORDPRESS_DB=
WORDPRESS_USER=
WORDPRESS_PASSWORD=