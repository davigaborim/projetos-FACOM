#Secret to sign JWT tokens
JWT_SECRET=

#Token expiration time
JWT_EXPIRES_IN=1h

#Default administrator email
EMAIL_GOD=goduser@email.com     #example email, can be changed

#Default administrator password
#Requirements: minimum 6 characters, at least 1 lowercase, 1 uppercase, 1 special character, and 1 number
SENHA_GOD=

#Database connection
#Inside Docker, MARIA_HOST should be db (service name in docker-compose)
#Outside Docker use "localhost"
MARIA_HOST=db
MARIA_PORT=3306
MARIA_DB=
MARIA_USER=
MARIA_PASSWORD=
MARIA_ROOT_PASSWORD=

#Execution environment ("production" or "development")
NODE_ENV=production

#CORS allowed origins, separated by comma
ALLOWED_ORIGINS=https://dominio.com.br,http://localhost:3000,http://localhost:3001

#Port exposed on the server (must be available on the host machine)
HOST_PORT=3001
