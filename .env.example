#Segredo para assinar os tokens JWT
JWT_SECRET=

#Tempo de expiração dos tokens
JWT_EXPIRES_IN=1h

#Senha do administrador padrão
#Requisitos: mínimo 6 caracteres, pelo menos 1 minúsculo, 1 maiúsculo, 1 especial e 1 número
SENHA_GOD=

#Conexão com o banco de dados
#Dentro do Docker, MARIA_HOST deve ser db (nome do serviço no docker-compose)
#Fora do Docker, use "localhost"
MARIA_HOST=db
MARIA_PORT=3306
MARIA_DB=
MARIA_USER=
MARIA_PASSWORD=
MARIA_ROOT_PASSWORD=

#Ambiente de execução ("production" ou "development")
NODE_ENV=production

#Origens permitidas pelo CORS, separadas por vírgula
ALLOWED_ORIGINS=https://dominio.com.br,http://localhost:3000,http://localhost:3001

#Porta exposta no servidor (deve estar disponível na máquina host)
HOST_PORT=3001